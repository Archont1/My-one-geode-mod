    "tags": [],
    "description": "",



    "settings": {
        "Arithmetic": { "type": "title" },
        "num0": {
            "type": "float",
            "name": "Number_one",
            "default": 0
        },

         "Operation": {
            "type": "int",
            "default": 1,
            "min": 1,
            "max": 4,
            "description": "1 = plus, 2 = minus, 3 = multiply, 4 = divide."
        },

        "num1": {
            "type": "float",
            "name": "Number_two",
            "default": 0
         },

        "last_answer": {
        "type": "float",
        "default": 0,
        "description": "This is the last answer. Displayed only after reboot.",
         "control": {
         "slider": false
         }
        }


        
    }
}
